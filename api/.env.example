# AD User API Configuration
# Copy to .env and fill in your values

# API authentication
AD_API_KEY=your-secure-api-key-here

# AD connection
AD_SERVER=ldaps://your-ad-server:636
AD_BIND_USER=CN=ServiceAccount,OU=Service Accounts,DC=example,DC=com
AD_BIND_PASSWORD=your-bind-password

# AD organizational structure
AD_STUDENTS_OU=OU=Students,DC=example,DC=com
AD_USERS_SEARCH_BASE=DC=example,DC=com
AD_STUDENTS_GROUP_DN=CN=Students,OU=Groups,DC=example,DC=com

# Allowed email domains (comma-separated)
AD_ALLOWED_DOMAINS=@example.edu

# API server binding (default: localhost only)
AD_API_HOST=127.0.0.1
AD_API_PORT=5000
